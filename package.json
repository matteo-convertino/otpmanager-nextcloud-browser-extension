{
  "name": "otpmanager-nextcloud-browser-extension",
  "description": "Official browser extension for accessing OTP Manager accounts from a Nextcloud server.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:debug": "wxt --debug --level debug",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "compile:watch": "tsc --noEmit --watch",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@mantine/core": "^9.3.2",
    "@mantine/form": "^9.3.2",
    "@mantine/hooks": "^9.3.2",
    "@mantine/notifications": "^9.3.2",
    "@tabler/icons-react": "^3.34.1",
    "axios": "^1.18.0",
    "crypto-es": "^3.1.3",
    "lottie-react": "^2.4.1",
    "otpauth": "^9.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.26"
  }
}
